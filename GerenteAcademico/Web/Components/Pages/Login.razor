@page "/{academia}/login"
@rendermode InteractiveServer
@layout EmptyLayout
@inherits LoginBase

<div class="login-container d-flex align-items-center justify-content-center">
    <div class="card shadow login-card">
        <div class="card-body">

            @if (!string.IsNullOrEmpty(LogoUrl))
            {
                <div class="text-center mb-3">
                    <img src="@LogoUrl" alt="Logo" class="img-fluid login-logo" />
                </div>
            }

            @* <h4 class="text-center mb-4 fw-bold">@NombreAcademia</h4> *@

            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input class="form-control form-control-lg" @bind="Username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" class="form-control form-control-lg" @bind="Password" />
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger mt-2">@ErrorMessage</div>
            }

            <button class="btn btn-primary btn-lg w-100 mt-2" @onclick="DoLogin">
                Iniciar sesión
            </button>
        </div>
    </div>
</div>
