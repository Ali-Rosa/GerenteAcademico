@page "/{academia}/configuraciones/usuarios"
@rendermode InteractiveServer
@layout MainLayout
@using GerenteAcademico.Web.Components.Components.Usuarios
@using GerenteAcademico.Web.Services
@using GerenteAcademico.Application.Dtos.Usuarios
@inject NavigationManager Navigation
@inject AcademiaState AcademiaState
@inject HttpClient Http
@inject ILogger<UsuariosPage> Logger
@inject IJSRuntime JSRuntime

<div class="usuarios-container">
    @if (IsLoading)
    {
        <div class="d-flex align-items-center justify-content-center" style="min-height: 400px;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="page-header mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="page-title">👥 Gestión de Usuarios</h2>
                    <p class="page-subtitle">Administra los usuarios de la academia</p>
                </div>
                <button class="btn btn-primary btn-lg" @onclick="OpenCreateForm">
                    <span class="me-2">➕</span> Nuevo Usuario
                </button>
            </div>
        </div>

        <!-- Messages -->
        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <span>✅</span> @SuccessMessage
                <button type="button" class="btn-close" @onclick="ClearMessages"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <span>❌</span> @ErrorMessage
                <button type="button" class="btn-close" @onclick="ClearMessages"></button>
            </div>
        }

        <!-- Form Section (shown when creating/editing) -->
        @if (ShowForm)
        {
            <div class="form-section mb-4">
                <UsuarioForm 
                    Academia="@AcademiaState.Codigo"
                    UsuarioId="@EditingUsuarioId"
                    OnSaved="@OnFormSaved"
                    OnCancelled="@OnFormCancelled"
                />
            </div>
        }

        <!-- Users List Section -->
        @if (!ShowForm)
        {
            <div class="list-section">
                <UsuariosList 
                    Academia="@AcademiaState.Codigo"
                    Usuarios="@Usuarios"
                    IsLoading="@IsLoadingUsers"
                    OnEdit="@OpenEditForm"
                    OnDelete="@OnDeleteUsuario"
                    OnRefresh="@LoadUsuarios"
                />
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string? academia { get; set; }

    private List<UsuarioDto> Usuarios = new();
    private bool IsLoading = true;
    private bool IsLoadingUsers = false;
    private bool ShowForm = false;
    private int? EditingUsuarioId = null;
    private string SuccessMessage = string.Empty;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsuarios();
    }

    private async Task LoadUsuarios()
    {
        IsLoadingUsers = true;
        try
        {
            // La ruta API debe incluir el código de academia
            var response = await Http.GetAsync($"/{AcademiaState.Codigo}/api/usuarios");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                Usuarios = System.Text.Json.JsonSerializer.Deserialize<List<UsuarioDto>>(
                    json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                ) ?? new();
                IsLoading = false;
            }
            else
            {
                ErrorMessage = $"Error al cargar los usuarios: {response.StatusCode}";
                Logger.LogError($"Error: {response.StatusCode}");
                IsLoading = false;  // ✅ Poner en false incluso si hay error
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error al cargar los usuarios: {ex.Message}";
            Logger.LogError(ex, "Error loading usuarios");
            IsLoading = false;  // ✅ Poner en false incluso si hay excepción
        }
        finally
        {
            IsLoadingUsers = false;
        }
    }

    private void OpenCreateForm()
    {
        EditingUsuarioId = null;
        ShowForm = true;
        ClearMessages();
    }

    private void OpenEditForm(int usuarioId)
    {
        EditingUsuarioId = usuarioId;
        ShowForm = true;
        ClearMessages();
    }

    private async Task OnFormSaved()
    {
        ShowForm = false;
        SuccessMessage = EditingUsuarioId == null 
            ? "Usuario creado exitosamente" 
            : "Usuario actualizado exitosamente";
        await LoadUsuarios();
    }

    private void OnFormCancelled()
    {
        ShowForm = false;
        ClearMessages();
    }

    private async Task OnDeleteUsuario(int usuarioId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Deseas eliminar este usuario?"))
        {
            try
            {
                var response = await Http.DeleteAsync($"/{AcademiaState.Codigo}/api/usuarios/{usuarioId}");
                if (response.IsSuccessStatusCode)
                {
                    SuccessMessage = "Usuario eliminado exitosamente";
                    await LoadUsuarios();
                }
                else
                {
                    ErrorMessage = "Error al eliminar el usuario";
                }
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Error al eliminar el usuario: {ex.Message}";
                Logger.LogError(ex, "Error deleting usuario");
            }
        }
    }

    private void ClearMessages()
    {
        SuccessMessage = string.Empty;
        ErrorMessage = string.Empty;
    }
}

<style>
    .usuarios-container {
        padding: 20px;
    }

    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        color: #1f2937;
        font-weight: 700;
        font-size: 28px;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #6b7280;
        font-size: 14px;
        margin: 0;
    }

    .form-section {
        background: white;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .list-section {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .alert {
        border-radius: 8px;
        border: 1px solid transparent;
        margin-bottom: 20px;
    }
</style>
