@using GerenteAcademico.Application.Dtos.Usuarios
@using System.Text.Json
@inject HttpClient Http
@inject ILogger<UsuarioForm> Logger

<div class="usuario-form">
    <div class="form-header mb-4">
        <h4>@(UsuarioId.HasValue ? "Editar Usuario" : "Nuevo Usuario")</h4>
        <p class="text-muted">Completa los datos del usuario</p>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <span>❌</span> @ErrorMessage
            <button type="button" class="btn-close" @onclick="@(() => ErrorMessage = "")"></button>
        </div>
    }

    <form @onsubmit="HandleSubmit">
        <div class="row">
            <!-- Nombre -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Nombre *</label>
                <input type="text" class="form-control" @bind="FormData.Nombre" required />
            </div>

            <!-- Apellido -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Apellido</label>
                <input type="text" class="form-control" @bind="FormData.Apellido" />
            </div>

            <!-- Email -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Email *</label>
                <input type="email" class="form-control" @bind="FormData.Email" required />
            </div>

            <!-- Username -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Usuario *</label>
                <input type="text" class="form-control" @bind="FormData.Username" required />
            </div>

            <!-- Contraseña -->
            <div class="col-md-6 mb-3">
                <label class="form-label">@(UsuarioId.HasValue ? "Contraseña (dejar en blanco para no cambiar)" : "Contraseña") *</label>
                <input type="password" class="form-control" @bind="FormData.Password" 
                       required="@(!UsuarioId.HasValue)" />
            </div>

            <!-- Rol -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Rol *</label>
                <select class="form-control" @bind="FormData.RolId" required>
                    <option value="">Selecciona un rol</option>
                    @foreach (var rol in Roles)
                    {
                        <option value="@rol.Id">@rol.Nombre</option>
                    }
                </select>
            </div>

            <!-- Documentación -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Tipo de Documento</label>
                <select class="form-control" @bind="FormData.TipoDocumentacion">
                    <option value="">Selecciona un tipo</option>
                    <option value="DUI">DUI</option>
                    <option value="Pasaporte">Pasaporte</option>
                    <option value="Cédula">Cédula</option>
                    <option value="RUC">RUC</option>
                </select>
            </div>

            <!-- Número de Documentación -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Número de Documento *</label>
                <input type="text" class="form-control" @bind="FormData.Documentacion" required />
            </div>

            <!-- Teléfono -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Teléfono *</label>
                <input type="tel" class="form-control" @bind="FormData.Telefono" required />
            </div>

            <!-- Teléfono Emergencia -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Teléfono de Emergencia</label>
                <input type="tel" class="form-control" @bind="FormData.TelefonoEmergencia" />
            </div>

            <!-- Género -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Género</label>
                <select class="form-control" @bind="FormData.Genero">
                    <option value="">Selecciona</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                    <option value="O">Otro</option>
                </select>
            </div>

            <!-- Fecha de Nacimiento -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Fecha de Nacimiento</label>
                <input type="date" class="form-control" @bind="FormData.FechaNacimiento" />
            </div>

            <!-- Nacionalidad -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Nacionalidad</label>
                <input type="text" class="form-control" @bind="FormData.Nacionalidad" />
            </div>

            <!-- Dirección -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Dirección</label>
                <input type="text" class="form-control" @bind="FormData.Direccion" />
            </div>

            <!-- Estado Activo -->
            <div class="col-md-12 mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" @bind="FormData.Activo" id="activo" />
                    <label class="form-check-label" for="activo">
                        Usuario Activo
                    </label>
                </div>
            </div>
        </div>

        <!-- Buttons -->
        <div class="form-actions mt-4">
            <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Guardando...</span>
                }
                else
                {
                    <span>💾 @(UsuarioId.HasValue ? "Actualizar" : "Crear")</span>
                }
            </button>
            <button type="button" class="btn btn-secondary" @onclick="HandleCancel" disabled="@IsSubmitting">
                Cancelar
            </button>
        </div>
    </form>
</div>

@code {
    [Parameter]
    public string Academia { get; set; } = default!;

    [Parameter]
    public int? UsuarioId { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private CreateUpdateUsuarioDto FormData = new() { Activo = true };
    private List<RolDto> Roles = new();
    private string ErrorMessage = string.Empty;
    private bool IsSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        if (UsuarioId.HasValue)
        {
            await LoadUsuario();
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            var url = $"/{Academia}/api/roles";
            Logger.LogInformation($"Cargando roles desde: {url}");

            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                Logger.LogInformation($"Respuesta de roles: {json}");

                Roles = JsonSerializer.Deserialize<List<RolDto>>(
                    json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                ) ?? new();

                Logger.LogInformation($"Roles cargados: {Roles.Count}");
            }
            else
            {
                Logger.LogWarning($"Error al cargar roles: {response.StatusCode}");
                // Si falla, intentar sin el código de academia (fallback)
                var fallbackResponse = await Http.GetAsync("/api/roles");
                if (fallbackResponse.IsSuccessStatusCode)
                {
                    var json = await fallbackResponse.Content.ReadAsStringAsync();
                    Roles = JsonSerializer.Deserialize<List<RolDto>>(
                        json,
                        new JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                    ) ?? new();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando roles");
        }
    }

    private async Task LoadUsuario()
    {
        try
        {
            var response = await Http.GetAsync($"/{Academia}/api/usuarios/{UsuarioId}");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var usuario = JsonSerializer.Deserialize<UsuarioDto>(
                    json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                );

                if (usuario != null)
                {
                    FormData = new CreateUpdateUsuarioDto
                    {
                        Nombre = usuario.Nombre,
                        Apellido = usuario.Apellido,
                        Email = usuario.Email,
                        Username = usuario.Username,
                        Documentacion = usuario.Documentacion,
                        TipoDocumentacion = usuario.TipoDocumentacion,
                        Telefono = usuario.Telefono,
                        TelefonoEmergencia = usuario.TelefonoEmergencia,
                        Direccion = usuario.Direccion,
                        Genero = usuario.Genero,
                        Nacionalidad = usuario.Nacionalidad,
                        FechaNacimiento = usuario.FechaNacimiento,
                        RolId = usuario.RolId,
                        Activo = usuario.Activo
                    };
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading usuario");
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(FormData.Nombre) || 
            string.IsNullOrWhiteSpace(FormData.Email) ||
            string.IsNullOrWhiteSpace(FormData.Username) ||
            string.IsNullOrWhiteSpace(FormData.Documentacion) ||
            string.IsNullOrWhiteSpace(FormData.Telefono) ||
            FormData.RolId <= 0)
        {
            ErrorMessage = "Por favor completa todos los campos requeridos";
            return;
        }

        if (!UsuarioId.HasValue && string.IsNullOrWhiteSpace(FormData.Password))
        {
            ErrorMessage = "La contraseña es requerida para nuevos usuarios";
            return;
        }

        IsSubmitting = true;
        try
        {
            HttpResponseMessage response;
            if (UsuarioId.HasValue)
            {
                response = await Http.PutAsJsonAsync($"/{Academia}/api/usuarios/{UsuarioId}", FormData);
            }
            else
            {
                response = await Http.PostAsJsonAsync($"/{Academia}/api/usuarios", FormData);
            }

            if (response.IsSuccessStatusCode)
            {
                await OnSaved.InvokeAsync();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error al guardar: {ex.Message}";
            Logger.LogError(ex, "Error saving usuario");
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task HandleCancel()
    {
        await OnCancelled.InvokeAsync();
    }

    public class RolDto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = default!;
        public bool Activo { get; set; }
    }
}

<style>
    .usuario-form {
        padding: 20px;
    }

    .form-header h4 {
        color: #1f2937;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .form-header p {
        margin: 0;
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-control {
        border-color: #d1d5db;
        padding: 10px 12px;
        border-radius: 6px;
    }

    .form-control:focus {
        border-color: #3366cc;
        box-shadow: 0 0 0 3px rgba(51, 102, 204, 0.1);
    }

    .form-actions {
        display: flex;
        gap: 12px;
    }

    .btn {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 600;
    }
</style>
