@using GerenteAcademico.Application.Dtos.Roles
@using System.Text.Json
@inject HttpClient Http
@inject ILogger<RolForm> Logger

<div class="rol-form">
    <div class="form-header mb-4">
        <h4>@(RolId.HasValue ? "Editar Rol" : "Nuevo Rol")</h4>
        <p class="text-muted">Completa los datos del rol</p>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <span>❌</span> @ErrorMessage
            <button type="button" class="btn-close" @onclick="@(() => ErrorMessage = "")"></button>
        </div>
    }

    <form @onsubmit="HandleSubmit">
        <div class="row">
            <!-- Nombre -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Nombre del Rol *</label>
                <input type="text" class="form-control" @bind="FormData.Nombre" required placeholder="Ej: Docente, Alumno, Admin..." />
            </div>

            <!-- Descripción -->
            <div class="col-md-6 mb-3">
                <label class="form-label">Descripción</label>
                <input type="text" class="form-control" @bind="FormData.Descripcion" placeholder="Describe el propósito del rol" />
            </div>

            <!-- Activo -->
            <div class="col-md-6 mb-3">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" @bind="FormData.Activo" id="activo" />
                    <label class="form-check-label" for="activo">
                        Rol Activo
                    </label>
                </div>
            </div>
        </div>

        <!-- Buttons -->
        <div class="form-actions mt-4">
            <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Guardando...</span>
                }
                else
                {
                    <span>💾 @(RolId.HasValue ? "Actualizar" : "Crear")</span>
                }
            </button>
            <button type="button" class="btn btn-secondary" @onclick="HandleCancel" disabled="@IsSubmitting">
                Cancelar
            </button>
        </div>
    </form>
</div>

@code {
    [Parameter]
    public string Academia { get; set; } = default!;

    [Parameter]
    public int? RolId { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private CreateUpdateRolDto FormData = new() { Activo = true };
    private string ErrorMessage = string.Empty;
    private bool IsSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        if (RolId.HasValue)
        {
            await LoadRol();
        }
    }

    private async Task LoadRol()
    {
        try
        {
            var response = await Http.GetAsync($"/{Academia}/api/roles/{RolId}");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var rol = JsonSerializer.Deserialize<RolDto>(
                    json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }
                );

                if (rol != null)
                {
                    FormData = new CreateUpdateRolDto
                    {
                        Nombre = rol.Nombre,
                        Descripcion = rol.Descripcion,
                        Activo = rol.Activo
                    };
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading rol");
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(FormData.Nombre))
        {
            ErrorMessage = "El nombre del rol es requerido";
            return;
        }

        IsSubmitting = true;
        try
        {
            HttpResponseMessage response;
            if (RolId.HasValue)
            {
                response = await Http.PutAsJsonAsync($"/{Academia}/api/roles/{RolId}", FormData);
            }
            else
            {
                response = await Http.PostAsJsonAsync($"/{Academia}/api/roles", FormData);
            }

            if (response.IsSuccessStatusCode)
            {
                await OnSaved.InvokeAsync();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Error al guardar el rol: {response.StatusCode}";
                Logger.LogError($"Error response: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error al guardar el rol: {ex.Message}";
            Logger.LogError(ex, "Error saving rol");
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task HandleCancel()
    {
        await OnCancelled.InvokeAsync();
    }
}

<style>
    .rol-form {
        background: white;
        border-radius: 8px;
    }

    .form-header {
        padding-bottom: 16px;
        border-bottom: 1px solid #e5e7eb;
    }

    .form-header h4 {
        color: #1f2937;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .form-header .text-muted {
        color: #6b7280;
        font-size: 14px;
    }

    .form-label {
        color: #374151;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-control {
        border-color: #d1d5db;
        border-radius: 6px;
        padding: 10px 12px;
        font-size: 14px;
    }

    .form-control:focus {
        border-color: #3366cc;
        box-shadow: 0 0 0 3px rgba(51, 102, 204, 0.1);
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        margin-top: 4px;
        border-color: #d1d5db;
    }

    .form-check-input:checked {
        background-color: #3366cc;
        border-color: #3366cc;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        padding-top: 16px;
        border-top: 1px solid #e5e7eb;
    }

    .btn {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background-color: #3366cc;
        color: white;
        border: none;
    }

    .btn-primary:hover:not(:disabled) {
        background-color: #2852a0;
        transform: translateY(-2px);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-secondary {
        background-color: #e5e7eb;
        color: #374151;
        border: none;
    }

    .btn-secondary:hover:not(:disabled) {
        background-color: #d1d5db;
    }

    .alert {
        margin-bottom: 20px;
        border-radius: 6px;
        padding: 12px 16px;
    }
</style>
